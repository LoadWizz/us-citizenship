# =========================================================================
# backend/.env — GERÇEK DEĞERLERİ BURAYA DEĞİL, .env DOSYASINA YAZ
# (.env .gitignore'dadır; bu dosya yalnız şablondur)
# =========================================================================

# Stripe (test modu anahtarlarıyla başla: dashboard.stripe.com/test/apikeys)
# NOT: gerçek anahtar "sk_test_" / "sk_live_" ile başlar — yer tutucular
# GitHub secret-tarayıcısını tetiklememek için bilerek farklı yazıldı.
STRIPE_SECRET_KEY=BURAYA-sk-ile-baslayan-gizli-anahtar
STRIPE_WEBHOOK_SECRET=BURAYA-whsec-ile-baslayan-deger

# Uzun rastgele bir dize üret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Uygulamanın adresleri (virgülle ayır)
ALLOWED_ORIGINS=https://loadwizz.github.io,http://localhost:8471

# Stripe Dashboard > Products'ta oluşturduğun Price ID'leri
PRICE_PREP_MONTHLY=price_XXXX
PRICE_PREP_YEARLY=price_XXXX
PRICE_PRO_MONTHLY=price_XXXX
PRICE_PRO_YEARLY=price_XXXX
PRICE_LIFETIME=price_XXXX

# Geri yükleme e-posta doğrulaması (İSTEĞE BAĞLI — resend.com, ücretsiz katman yeter)
# Anahtar girilirse /restore 6 haneli kod e-postalar; girilmezse eski davranış.
# MAIL_FROM: Resend'de doğrulanmış alan adresi (test için onboarding@resend.dev çalışır)
RESEND_API_KEY=
MAIL_FROM=US Citizenship <onboarding@resend.dev>

# Gerçek Stripe'a geçerken "false" yap (veya satırı sil)
MOCK_STRIPE=true
